# Emergence Kernel Configuration
# This file contains kernel build configuration options.
#
# Usage:
#   make                    # Use default values from this file
#   make CONFIG_TESTS_SPINLOCK=1  # Override specific option
#
# To create a local override (not committed to git):
#   cp kernel.config .config
#   # Edit .config with your preferences

# ========================================================================
# Test Configuration
# ========================================================================

# Spin lock tests - Test synchronization primitives (spinlocks, rwlocks)
# Set to 1 to enable, 0 to disable
CONFIG_TESTS_SPINLOCK ?= 0

# PMM (Physical Memory Manager) tests - Test memory allocation
# Set to 1 to enable, 0 to disable
CONFIG_TESTS_PMM ?= 1

# Slab allocator tests - Test small object allocation
# Set to 1 to enable, 0 to disable
CONFIG_TESTS_SLAB ?= 1

# APIC timer test - Test APIC timer interrupts with quote output
# Set to 1 to enable, 0 to disable
CONFIG_TESTS_APIC_TIMER ?= 1

# Boot tests - Basic kernel boot verification
# Set to 1 to enable, 0 to disable
CONFIG_TESTS_BOOT ?= 1

# SMP tests - SMP startup and multi-CPU verification
# Set to 1 to enable, 0 to disable
CONFIG_TESTS_SMP ?= 1

# PCD tests - Page Control Data initialization and tracking
# Set to 1 to enable, 0 to disable
CONFIG_TESTS_PCD ?= 1

# Minilibc tests - Minimal string library tests
# Set to 1 to enable, 0 to disable
CONFIG_TESTS_MINILIBC ?= 1

# User mode syscall tests - Test SYSCALL/SYSRET and ring 3 execution
# Set to 1 to enable, 0 to disable
CONFIG_TESTS_USERMODE ?= 1

# Nested Kernel invariants tests - Verify 6 ASPLOS '15 invariants
# Set to 1 to enable, 0 to disable
CONFIG_TESTS_NK_INVARIANTS ?= 1

# Read-only visibility tests - Verify read-only mapping visibility
# Set to 1 to enable, 0 to disable
CONFIG_TESTS_NK_READONLY_VISIBILITY ?= 1

# Nested kernel fault injection tests - Test nested kernel write protection
# WARNING: These tests will cause intentional page faults and shutdown
# Set to 1 to enable, 0 to disable
CONFIG_TESTS_NK_FAULT_INJECTION ?= 0

# Monitor trampoline test - Test CR3 switching via trampoline
# Set to 1 to enable, 0 to disable
CONFIG_TESTS_NK_TRAMPOLINE ?=

# ========================================================================
# Nested Kernel Configuration
# ========================================================================

# Write protection verification - Verify Nested Kernel invariants at boot
# Confirms all 6 invariants are enforced on BSP and all APs
# Set to 1 to enable, 0 to disable
CONFIG_NK_WRITE_PROTECTION_VERIFY ?= 1

# ========================================================================
# Debug Configuration
# ========================================================================

# SMP AP startup debug marks - Output AP boot progression marks on serial
# Shows: H→G→3→A→P→L→X→D→S→Q→A→I→L→T→W
# Set to 1 to enable, 0 to disable
CONFIG_DEBUG_SMP_AP ?= 0

# PCD (Page Control Data) statistics dump - Show page type statistics at boot
# Set to 1 to enable, 0 to disable
CONFIG_DEBUG_PCD_STATS ?= 1

# Nested Kernel invariants verbose logging - Show detailed per-invariant results
# Set to 1 for detailed output (all 6 invariants with details)
# Set to 0 for summary only (just final PASS/FAIL)
CONFIG_DEBUG_NK_INVARIANTS_VERBOSE ?= 0
